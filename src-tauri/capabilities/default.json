{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Allow the main window to open and save Bloomdot project files.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/*.bloomdot" },
        { "path": "$HOME/**/*.bloomdot" }
      ]
    }
  ]
}
