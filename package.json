{
  "name": "blumdot-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "desktop": "npm run desktop:bundle && open ./src-tauri/target/debug/bundle/macos/Blumdot.app",
    "desktop:bundle": "tauri build --debug --bundles app --no-sign --ci",
    "desktop:raw": "npm run build && cargo run --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.41.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-fs": "^2.4.1",
    "@wterm/dom": "0.1.9",
    "@wterm/react": "0.1.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
